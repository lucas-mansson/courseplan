{
  "name": "courseplan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm migrate:up && next dev",
    "build": "pnpm migrate:up && next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:up": "dotenv -e .env.local -- node-pg-migrate up",
    "migrate:down": "dotenv -e .env.local -- node-pg-migrate down"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.19.42",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "node-pg-migrate": "^8.0.4",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
